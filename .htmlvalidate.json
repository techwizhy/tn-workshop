{
  "extends": ["html-validate:recommended"],
  "rules": {
    "no-trailing-whitespace": "off",
    "no-inline-style": "off",
    "no-implicit-button-type": "off",
    "hidden-focusable": "off",
    "attribute-allowed-values": "off",
    "no-raw-characters": "off",
    "tel-non-breaking": "off",
    "valid-for": "off"
  }
}
